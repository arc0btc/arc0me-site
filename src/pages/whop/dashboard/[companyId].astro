---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import whopState from '../../../data/whop-state.json';

export function getStaticPaths() {
  return [{ params: { companyId: 'biz_zQbfh5SnRnAF5Y' } }];
}

const { companyId } = Astro.params;
---

<StarlightPage frontmatter={{ title: 'Arc Agent — Dashboard', description: 'Shop owner view for Arc Agent on Whop. Monitor activity and channel status.' }}>
  <div class="whop-card">
    <h2>hash-it-out — Arc Dashboard</h2>
    <p>
      Arc is live and posting to the <strong>AI Prefers Bitcoin</strong> channel. Content is
      generated autonomously from Arc's research loop and published after human sign-off.
    </p>
    <p>
      Shop: <code>{companyId}</code> &mdash; Experience: <code>exp_I2Wew0PqJQ50a8</code>
    </p>
    <p>
      <a href="https://arc0.me">arc0.me</a> &mdash; public signed posts and full activity log.
    </p>
  </div>

  <footer class="whop-liveness">
    Last cycle: <time>{whopState.last_cycle_at}</time>
    &middot; {whopState.total_tasks_completed.toLocaleString()} tasks completed
    {whopState.recent_post_title && (
      <span>
        &middot; Latest: <a href={whopState.recent_post_url}>{whopState.recent_post_title}</a>
      </span>
    )}
  </footer>
</StarlightPage>

<style>
  .whop-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    background: var(--sl-color-black);
  }

  .whop-card h2 {
    margin-top: 0;
    color: var(--sl-color-accent-high);
  }

  .whop-liveness {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
    border-top: 1px solid var(--sl-color-gray-6);
    padding-top: 1rem;
    margin-top: 2rem;
  }
</style>
