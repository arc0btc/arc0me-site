---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('docs', ({ id, data }) =>
    id.startsWith('blog/') && !data.draft
  );

  const tagMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    for (const tag of (post.data.tags ?? [])) {
      const list = tagMap.get(tag) ?? [];
      list.push(post);
      tagMap.set(tag, list);
    }
  }

  return [...tagMap.entries()].map(([tag, posts]) => ({
    params: { tag },
    props: {
      posts: posts.sort((a, b) => {
        const aDate = a.data.date ?? new Date(0);
        const bDate = b.data.date ?? new Date(0);
        return bDate.getTime() - aDate.getTime();
      }),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<StarlightPage
  frontmatter={{
    title: `#${tag}`,
    description: `Posts tagged #${tag}`,
  }}
>
  <p><a href="/tags">← All tags</a> &nbsp;·&nbsp; {posts.length} post{posts.length !== 1 ? 's' : ''}</p>

  <ul class="tag-post-list">
    {posts.map(post => {
      const slug = post.id.replace(/^blog\//, '').replace(/\.mdx?$/, '');
      const date = post.data.date
        ? new Date(post.data.date).toISOString().slice(0, 10)
        : null;
      return (
        <li class="tag-post-item">
          <a href={`/blog/${slug}`} class="tag-post-title">{post.data.title}</a>
          {date && <span class="tag-post-date">{date}</span>}
          {post.data.description && (
            <p class="tag-post-desc">{post.data.description}</p>
          )}
        </li>
      );
    })}
  </ul>
</StarlightPage>

<style>
  .tag-post-list {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tag-post-item {
    border-left: 2px solid var(--arc-border-accent);
    padding-left: 1rem;
  }

  .tag-post-title {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--sl-color-white);
    text-decoration: none;
    display: block;
    margin-bottom: 0.25rem;
  }

  .tag-post-title:hover {
    color: var(--arc-gold);
  }

  .tag-post-date {
    font-size: 0.75rem;
    font-family: var(--sl-font-mono);
    color: var(--sl-color-gray-3);
  }

  .tag-post-desc {
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    margin: 0.375rem 0 0;
    line-height: 1.5;
  }
</style>
