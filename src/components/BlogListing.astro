---
import { getCollection } from 'astro:content';

const posts = await getCollection('docs', (entry) =>
  entry.id.startsWith('blog/') && entry.id !== 'blog/index'
);

// Sort newest first
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

// Collect all unique tags
const allTags = new Set<string>();
sortedPosts.forEach((post) => {
  post.data.tags?.forEach((tag) => allTags.add(tag));
});
const tagList = [...allTags].sort();

// Format date in UTC to avoid timezone shift
function formatDate(date: Date | undefined): string {
  if (!date) return '';
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[date.getUTCMonth()]} ${date.getUTCDate()}, ${date.getUTCFullYear()}`;
}

// Build slug from post id
function getSlug(id: string): string {
  return id.replace('blog/', '').replace('.mdx', '').replace(/\.mdx$/, '');
}
---

<div class="blog-listing">
  <nav class="blog-tags" aria-label="Filter by tag">
    <button class="blog-tag active" data-tag="all">All</button>
    {tagList.map((tag) => (
      <button class="blog-tag" data-tag={tag}>{tag}</button>
    ))}
  </nav>

  <ol class="blog-posts" reversed>
    {sortedPosts.map((post) => {
      const tags = post.data.tags || [];
      const slug = getSlug(post.id);
      const hasSig = post.data.signatures?.btc?.signature;
      return (
        <li class="blog-post-item" data-tags={tags.join(',')}>
          <a href={`/blog/${slug}/`}>
            <time datetime={post.data.date?.toISOString().split('T')[0]}>
              {formatDate(post.data.date)}
            </time>
            <span class="blog-post-title">
              {post.data.title}
              {hasSig && <span class="signed-badge" title="Cryptographically signed">&#x2713;</span>}
            </span>
          </a>
        </li>
      );
    })}
  </ol>

  <p class="blog-post-count">
    <span id="visible-count">{sortedPosts.length}</span> of {sortedPosts.length} posts
  </p>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const tags = document.querySelectorAll<HTMLButtonElement>('.blog-tag');
    const posts = document.querySelectorAll<HTMLLIElement>('.blog-post-item');
    const countEl = document.getElementById('visible-count');

    tags.forEach((btn) => {
      btn.addEventListener('click', () => {
        tags.forEach((t) => t.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.tag;
        let visible = 0;
        posts.forEach((post) => {
          const postTags = post.dataset.tags?.split(',') || [];
          const show = filter === 'all' || postTags.includes(filter!);
          post.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        if (countEl) countEl.textContent = String(visible);
      });
    });
  });
</script>

<style>
  .blog-listing {
    margin-top: 1.5rem;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--arc-border-subtle, #1e1e22);
  }

  .blog-tag {
    font-family: var(--sl-font);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--arc-border-default, #2a2a2e);
    border-radius: 4px;
    background: transparent;
    color: var(--sl-color-gray-3, #8b8b8b);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .blog-tag:hover {
    color: var(--sl-color-accent-high, #FFD666);
    border-color: var(--arc-border-accent, rgba(254, 194, 51, 0.25));
  }

  .blog-tag.active {
    color: var(--sl-color-black, #000);
    background: var(--sl-color-accent, #FEC233);
    border-color: var(--sl-color-accent, #FEC233);
  }

  .blog-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-post-item {
    border-bottom: 1px solid var(--arc-border-subtle, #1e1e22);
  }

  .blog-post-item:last-child {
    border-bottom: none;
  }

  .blog-post-item a {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: inherit;
    transition: color 0.15s ease;
  }

  .blog-post-item a:hover {
    color: var(--sl-color-accent-high, #FFD666);
  }

  .blog-post-item a:hover .blog-post-title {
    color: var(--sl-color-accent-high, #FFD666);
  }

  time {
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3, #8b8b8b);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 6.5rem;
  }

  .blog-post-title {
    color: var(--sl-color-gray-1, #eee);
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .signed-badge {
    display: inline-block;
    margin-left: 0.375rem;
    color: var(--sl-color-accent, #FEC233);
    font-size: 0.875em;
  }

  .blog-post-count {
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--sl-color-gray-4, #56595b);
  }

  @media (max-width: 30rem) {
    .blog-post-item a {
      flex-direction: column;
      gap: 0.125rem;
    }

    time {
      font-size: 0.75rem;
    }
  }
</style>
