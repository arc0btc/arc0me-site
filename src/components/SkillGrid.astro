---
import { catalog, type Skill } from '../data/catalog';

interface Props {
  filter?: 'all' | 'sensors';
}

const { filter = 'all' } = Astro.props;

const skills = filter === 'sensors'
  ? catalog.filter(s => s.hasSensor)
  : catalog;

// Group by category
const grouped = new Map<string, Skill[]>();
for (const skill of skills) {
  const list = grouped.get(skill.category) ?? [];
  list.push(skill);
  grouped.set(skill.category, list);
}

// Sort categories: Bitcoin & Stacks first, then AIBTC, then alpha
const categoryOrder = [
  'Bitcoin & Stacks',
  'AIBTC Platform',
  'Arc Infrastructure',
  'Publishing & Social',
  'GitHub & DevOps',
  'DeFi & Governance',
  'On-Chain Identity (ERC-8004)',
  'Quality & Compliance',
  'Development Tools',
  'Other',
];

const sortedCategories = [...grouped.keys()].sort(
  (a, b) => (categoryOrder.indexOf(a) ?? 99) - (categoryOrder.indexOf(b) ?? 99)
);

function formatInterval(minutes: number): string {
  if (minutes >= 1440) return `${Math.round(minutes / 1440)}d`;
  if (minutes >= 60) return `${Math.round(minutes / 60)}h`;
  return `${minutes}m`;
}
---

<div class="skill-grid-wrapper">
  <div class="skill-stats">
    <span class="stat">{skills.length} {filter === 'sensors' ? 'sensors' : 'skills'}</span>
    <span class="stat-sep">/</span>
    <span class="stat">{skills.filter(s => s.hasSensor).length} sensors</span>
    <span class="stat-sep">/</span>
    <span class="stat">{skills.filter(s => s.hasCli).length} with CLI</span>
    <span class="stat-sep">/</span>
    <span class="stat">{new Set(skills.map(s => s.category)).size} categories</span>
  </div>

  {sortedCategories.map(category => {
    const categorySkills = grouped.get(category)!;
    return (
      <section class="skill-category">
        <h2 class="category-heading" id={category.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
          {category}
          <span class="category-count">{categorySkills.length}</span>
        </h2>
        <div class="skill-grid">
          {categorySkills.map(skill => (
            <div class="skill-card">
              <div class="skill-header">
                <h3 class="skill-name">{skill.name}</h3>
                <div class="skill-icons">
                  {skill.hasSensor && (
                    <span class="skill-icon" title={`Sensor: every ${formatInterval(skill.sensorInterval!)}`}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                      </svg>
                      <span class="icon-label">{formatInterval(skill.sensorInterval!)}</span>
                    </span>
                  )}
                  {skill.hasCli && (
                    <span class="skill-icon" title="Has CLI">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="4 17 10 11 4 5"/>
                        <line x1="12" y1="19" x2="20" y2="19"/>
                      </svg>
                    </span>
                  )}
                  {skill.hasAgent && (
                    <span class="skill-icon" title="Has Agent briefing">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                      </svg>
                    </span>
                  )}
                </div>
              </div>
              <p class="skill-description">{skill.description}</p>
              {skill.tags.length > 0 && (
                <div class="skill-tags">
                  {skill.tags.map(tag => (
                    <span class="skill-tag">{tag}</span>
                  ))}
                </div>
              )}
              <div class="skill-install">
                <code>skills/{skill.name}/</code>
              </div>
            </div>
          ))}
        </div>
      </section>
    );
  })}
</div>
